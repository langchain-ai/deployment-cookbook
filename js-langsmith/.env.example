# Required: OpenAI API key used by the agent and its subagents.
OPENAI_API_KEY=sk-...

# Required for LangSmith Deployment (langgraph deploy / langgraph dev).
LANGSMITH_API_KEY=lsv2-...

# Optional: name for the deployment (defaults to the directory name).
# LANGSMITH_DEPLOYMENT_NAME=deployment-cookbook-agent

# Optional: enable LangSmith tracing.
# LANGSMITH_TRACING=true

# --- Client (Vite) — only needed for production / remote deployment testing ---

# LangSmith deployment root URL (no path suffix).
# Local dev: leave unset — Vite proxies /api/langgraph → http://localhost:2024.
# Production: https://your-app.us.langgraph.app
VITE_AGENT_API_URL=

# Required when VITE_AGENT_API_URL points at a LangSmith deployment.
VITE_LANGSMITH_API_KEY=lsv2-...
