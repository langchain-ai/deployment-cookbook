{
  "name": "js-langsmith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n agent,web -c blue,green \"pnpm dev:agent\" \"pnpm dev:web\"",
    "dev:agent": "langgraphjs dev --no-browser --host 127.0.0.1",
    "dev:web": "wait-on http-get://127.0.0.1:2024/ok && vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "langgraphjs deploy",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@langchain/core": "1.2.1",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/langgraph-sdk": "^1.9.24",
    "@langchain/openai": "^1.5.2",
    "@langchain/react": "^1.0.25",
    "deepagents": "^1.10.5",
    "langchain": "^1.5.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.4.0",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "typescript": "^6",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "packageManager": "pnpm@11.8.0"
}