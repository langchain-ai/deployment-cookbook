{
  "name": "js-langsmith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n agent,web -c blue,green \"pnpm dev:agent\" \"pnpm dev:web\"",
    "dev:agent": "langgraphjs dev --no-browser --host 127.0.0.1",
    "dev:web": "wait-on http-get://127.0.0.1:2024/ok && vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "langgraphjs deploy",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@langchain/core": "1.1.48",
    "@langchain/langgraph": "^1.3.7",
    "@langchain/langgraph-sdk": "^1.9.20",
    "@langchain/openai": "^1.4.7",
    "@langchain/react": "^1.0.20",
    "deepagents": "^1.10.2",
    "langchain": "^1.4.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.0",
    "typescript": "^5",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}