# LangSmith API key — used for BOTH deploying the agent
# (`pnpm run deploy` → `deepagents deploy`) and for the browser client to reach
# the hosted agent. Must belong to a workspace with Managed Deep Agents
# private-preview access.
#
# Vite exposes this to the client bundle via `envPrefix` (see vite.config.ts) —
# fine for a local demo; in production, proxy through your own backend instead
# of shipping the key.
LANGSMITH_API_KEY=lsv2-...

# Managed Deep Agent UUID printed by `pnpm run deploy` (not the agent name).
# Example: 585b5f3c-3409-4923-b0ed-79b86a8425e8
LANGSMITH_MANAGED_AGENT_ID=
